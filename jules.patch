 theorem optimal_granularity_tradeoff
-    (bias_coarse bias_fine variance_coarse variance_fine : ℝ)
-    (h_coarse_biased : bias_fine < bias_coarse)
-    (h_fine_variable : variance_coarse < variance_fine) :
