+    (benefit per unit R²). -/
+structure ClinicalBenefitModel where
+  alpha : ℝ
+  h_alpha : 0 < alpha
+
+/-- **Expected Clinical Benefit.**
+    The expected net clinical benefit from a PGS with variance explained R². -/
+noncomputable def expectedBenefit (m : ClinicalBenefitModel) (r2 : ℝ) : ℝ :=
+  m.alpha * r2
+
