+    have h_add : (σ_sq + σ_extra_sq) / (σ_extra_sq / bias_sq) = σ_sq / (σ_extra_sq / bias_sq) + σ_extra_sq / (σ_extra_sq / bias_sq) := by exact add_div σ_sq σ_extra_sq (σ_extra_sq / bias_sq)
+    rw [h_add, this]
