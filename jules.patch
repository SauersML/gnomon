+/-- **Recalibrated R².**
+    Proportion of variance explained after optimal recalibration,
+    given by the source R² multiplied by the squared effect correlation. -/
+noncomputable def recalibratedR2 (r2_source ρ_sq : ℝ) : ℝ :=
+  r2_source * ρ_sq
+
+/-- **Turnover Loss R².**
+    Non-recoverable R² loss due to effect turnover (changes in causal variants). -/
+noncomputable def turnoverLossR2 (r2_source ρ_sq : ℝ) : ℝ :=
+  r2_source * (1 - ρ_sq)
+
 /-- **Recalibration recovers R² up to effect turnover limit.**
