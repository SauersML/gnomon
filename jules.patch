+      have h1 : _σ_sq / n_T + σ_extra_sq / n_T < _σ_sq / n_T + bias_sq := by rwa [add_div] at h_lt
+      have h2 : σ_extra_sq / n_T < bias_sq := (add_lt_add_iff_left (_σ_sq / n_T)).mp h1
+      have h3 : σ_extra_sq < n_T * bias_sq := by
