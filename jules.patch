+/-- A formal predictive model that assigns risk scores to cis and trans configurations. -/
+structure PhasePredictor where
+  pred_cis : ℝ
+  pred_trans : ℝ
+
+/-- The structural error of any phase predictor is the sum of squared errors
+weighted by the configuration frequencies. -/
+noncomputable def phasePredictionError
+    (pred : PhasePredictor) (freq_cis interaction_cis interaction_trans : ℝ) : ℝ :=
+  freq_cis * (interaction_cis - pred.pred_cis) ^ 2 +
+    (1 - freq_cis) * (interaction_trans - pred.pred_trans) ^ 2
+
+/-- The average interaction contribution predicted by the model in a population. -/
+noncomputable def predictorAverage
+    (pred : PhasePredictor) (freq_cis : ℝ) : ℝ :=
+  freq_cis * pred.pred_cis + (1 - freq_cis) * pred.pred_trans
+
+/-- Transport bias is the difference between the model's predicted average interaction
+and the true average interaction in the target population. -/
+noncomputable def phaseTransportBias
+    (pred : PhasePredictor) (freq_cis_target interaction_cis interaction_trans : ℝ) : ℝ :=
+  |predictorAverage pred freq_cis_target -
+    averagePhaseInteraction freq_cis_target interaction_cis interaction_trans|
+
+/-- A phase-aware exact haplotype predictor that correctly assigns risks. -/
+def exactHaplotypePredictor (interaction_cis interaction_trans : ℝ) : PhasePredictor :=
+  { pred_cis := interaction_cis, pred_trans := interaction_trans }
+
 /-- Structural error from using a dosage-only predictor that cannot distinguish
 cis from trans configurations. The best dosage-only predictor within a fixed
 dosage class uses the population-average interaction, leaving this residual
 phase-misspecification error. -/
 noncomputable def dosagePhaseMisspecificationError
     (freq_cis interaction_cis interaction_trans : ℝ) : ℝ :=
-  freq_cis * (interaction_cis - averagePhaseInteraction freq_cis interaction_cis interaction_trans) ^ 2 +
-    (1 - freq_cis) *
-      (interaction_trans - averagePhaseInteraction freq_cis interaction_cis interaction_trans) ^ 2
+  phasePredictionError
+    { pred_cis := averagePhaseInteraction freq_cis interaction_cis interaction_trans
+      pred_trans := averagePhaseInteraction freq_cis interaction_cis interaction_trans }
+    freq_cis interaction_cis interaction_trans
 
 /-- A phase-aware haplotype predictor that tracks cis/trans configuration has no
 structural phase-misspecification error. -/
 noncomputable def haplotypePhasePredictionError : ℝ :=
   0
 
+theorem haplotypePhasePredictionError_eq_zero
+    (freq_cis interaction_cis interaction_trans : ℝ) :
+    phasePredictionError (exactHaplotypePredictor interaction_cis interaction_trans) freq_cis interaction_cis interaction_trans =
+      haplotypePhasePredictionError := by
+  unfold phasePredictionError exactHaplotypePredictor haplotypePhasePredictionError
+  ring
+
 /-- Transport bias from carrying a source-trained dosage approximation into a
 target population whose cis/trans configuration frequency differs. -/
 noncomputable def dosageTransportBias
