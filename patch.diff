    (h_higher_res : finemapResolution cs_eur < finemapResolution cs_afr) :
    cs_afr < cs_eur := by
  unfold finemapResolution at h_higher_res
  rw [div_lt_div_iff₀ h_eur_pos h_afr_pos] at h_higher_res
  linarith

